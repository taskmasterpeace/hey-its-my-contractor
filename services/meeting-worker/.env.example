# Meeting worker environment

# HTTP
PORT=8080
# Shared secret the web app must send as `Authorization: Bearer <secret>`
WORKER_SHARED_SECRET=dev-secret

# Postgres (same database the web app uses)
DATABASE_URL=postgresql://postgres:contractor_dev_password@localhost:5432/contractor_platform

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=meeting_transcripts

# OpenRouter (summary, action items, Q&A)
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Cron sweep schedule (node-cron syntax). Default: every 5 minutes.
SWEEP_CRON=*/5 * * * *
# Set to "false" to disable the in-process cron (e.g. if Fly runs a scheduled machine instead)
SWEEP_ENABLED=true
